// datasource and generator
 datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
 }

 generator client {
  provider = "prisma-client-js"
 }

 // Category enum covering top consumer categories
 enum Category {
  HOUSING
  GROCERIES
  TRANSPORTATION
  DINING
  UTILITIES
  ENTERTAINMENT
  HEALTH
  SHOPPING
  SUBSCRIPTIONS
  OTHER
 }

 model Transaction {
  id            Int       @id @default(autoincrement())
  date          DateTime
  description   String
  // store currency as integer cents for precision
  amountCents   Int
  category      Category
  source        String    @default("manual") // manual or csv
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([date])
  @@index([category])
 }

 // Budget per month per category
 model Budget {
  id           Int       @id @default(autoincrement())
  // month represented by first day of month in UTC
  month        DateTime
  category     Category
  amountCents  Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([month, category])
  @@index([month])
 }